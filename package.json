{
  "name": "@novacraft/core",
  "version": "0.1.0",
  "description": "NovaCraft UI — Zero-Dependency Framework-Agnostic Web Component Library",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./tokens": "./dist/css/tokens.css"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": ["**/*.css"],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "keywords": [
    "web-components",
    "custom-elements",
    "ui-library",
    "component-library",
    "shadow-dom",
    "design-system",
    "framework-agnostic",
    "zero-dependency",
    "typescript"
  ],
  "author": "mdehtisham",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mdehtisham/novacraft-ui.git"
  },
  "homepage": "https://mdehtisham.github.io/novacraft-ui",
  "bugs": {
    "url": "https://github.com/mdehtisham/novacraft-ui/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^2.1.0",
    "jsdom": "^25.0.0",
    "terser": "^5.36.0",
    "@vitest/coverage-v8": "^2.1.0",
    "storybook": "^8.4.0",
    "@storybook/web-components-vite": "^8.4.0",
    "@storybook/addon-essentials": "^8.4.0",
    "@storybook/addon-a11y": "^8.4.0",
    "@storybook/blocks": "^8.4.0",
    "lit": "^3.2.0"
  }
}
